DOMAIN ModCode IS String;
DOMAIN MTitle IS String;
DOMAIN MSem IS Int;
DOMAIN MCredit IS Int;

TYPE mc AS ModCode;
TYPE mt AS MTitle;
TYPE ms AS MSem;
TYPE cr AS MCredit;

RELATION module WITH mc, mt, ms, cr;

LOAD "./module.csv" INTO module;

LET a BE RENAME module ON amc, amt, ams, acr;
LET b BE RENAME module ON bmc, bmt, bms, bcr;
LET c BE RENAME module ON cmc, cmt, cms, ccr;
LET ab BE JOIN a AND b;
JOIN ab AND c;
