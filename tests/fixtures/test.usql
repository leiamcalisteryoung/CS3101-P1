DOMAIN ModCode IS String; 
DOMAIN MTitle IS String;
DOMAIN MSem IS Int;
DOMAIN MCredit IS Int;

TYPE mc AS ModCode;
TYPE mt AS MTitle;
TYPE ms AS MSem;
TYPE cr AS MCredit;

RELATION module WITH mc, mt, ms, cr;

LOAD "./module.csv" INTO module;

LET candlemas BE SELECT module WHERE ms=2;
PROJECT candlemas ON mc,mt,cr;